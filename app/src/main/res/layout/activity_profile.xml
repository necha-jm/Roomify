<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".ProfileActivity">

    <!-- Main Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Header Section with Profile Image and Rating -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="24dp">

                <!-- Profile Avatar -->
                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Profile picture"
                        android:padding="20dp"
                        app:tint="@color/primary_teal" />

                </androidx.cardview.widget.CardView>

                <!-- User Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Nestory Charles"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark" />

                <!-- Rating Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 5.00"
                        android:textSize="16sp"
                        android:textColor="@color/rating_gold"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Uwekaji alama"
                        android:textSize="14sp"
                        android:textColor="@color/text_gray" />
                </LinearLayout>
            </LinearLayout>

            <!-- Travel Plan Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_blue_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mpango kabambe wa safari"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_teal_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Pata mapendekezo ya safari kulingana na matukio kwenye kalenda yako"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:lineSpacingExtra="2dp" />

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="@color/primary_teal"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="10dp"
                        android:text="Unganisha kalenda"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        app:cornerRadius="30dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Settings Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="Mipangilio"
                android:textSize="14sp"
                android:textColor="@color/text_gray"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <!-- Settings List Items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:showDividers="middle"
                android:background="@color/white">

                <LinearLayout
                    style="@style/SettingItemStyle">

                    <TextView
                        style="@style/SettingTextStyle"
                        android:text="@string/taarifa_binafsi" />

                    <ImageView
                        style="@style/SettingIconStyle"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <LinearLayout
                    style="@style/SettingItemStyle">

                    <TextView
                        style="@style/SettingTextStyle"
                        android:text="Wasifu wa familia" />

                    <ImageView
                        style="@style/SettingIconStyle"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <LinearLayout
                    style="@style/SettingItemStyle">

                    <TextView
                        style="@style/SettingTextStyle"
                        android:text="@string/usalama" />

                    <ImageView
                        style="@style/SettingIconStyle"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <LinearLayout
                    style="@style/SettingItemStyle">

                    <TextView
                        style="@style/SettingTextStyle"
                        android:text="Kuingia katika akaunti na usalama" />

                    <ImageView
                        style="@style/SettingIconStyle"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <LinearLayout
                    style="@style/SettingItemStyle">

                    <TextView
                        style="@style/SettingTextStyle"
                        android:text="Faragha" />

                    <ImageView
                        style="@style/SettingIconStyle"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

            </LinearLayout>

            <!-- Saved Places Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="@string/maeneo_yaliyohifadhiwa"
                android:textSize="14sp"
                android:textColor="@color/text_gray"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <!-- Saved Places Items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:divider="@drawable/divider_line"
                android:showDividers="middle"
                android:background="@color/white">

                <LinearLayout
                    style="@style/SettingItemStyle">

                    <TextView
                        style="@style/SettingTextStyle"
                        android:text="Mwanzo" />

                    <ImageView
                        style="@style/SettingIconStyle"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <LinearLayout
                    style="@style/SettingItemStyle">

                    <TextView
                        style="@style/SettingTextStyle"
                        android:text="Safari" />

                    <ImageView
                        style="@style/SettingIconStyle"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <LinearLayout
                    style="@style/SettingItemStyle">

                    <TextView
                        style="@style/SettingTextStyle"
                        android:text="Akaunti" />

                    <ImageView
                        style="@style/SettingIconStyle"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:elevation="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
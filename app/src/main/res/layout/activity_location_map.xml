<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/surface"
    tools:context=".MainActivity">

    <!-- Google Map Fragment -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Modern Gradient Overlay for better visibility -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/gradient_overlay_top"
        android:alpha="0.6" />

    <!-- Enhanced Search Bar with Modern Design -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="20dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardPreventCornerOverlap="true"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/search_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_search"
                app:tint="?attr/colorPrimary"
                android:alpha="0.8" />

            <EditText
                android:id="@+id/search_edittext"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="@string/search_location_or_room"
                android:background="@null"
                android:padding="0dp"
                android:textSize="16sp"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                android:textColorHint="@color/text_secondary" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_location"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/todo"
                android:src="@drawable/ic_my_location"
                app:backgroundTint="?attr/colorPrimary"
                app:tint="@android:color/white"
                app:elevation="0dp"
                app:fabSize="mini" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Modern Bottom Sheet with Enhanced Design -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="120dp"
        app:behavior_hideable="false">

        <!-- Enhanced Bottom Sheet Handle with Ripple Effect -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bottom_sheet_handle_background"
            android:clickable="true"
            android:focusable="true">

            <View
                android:layout_width="48dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bottom_sheet_handle"
                android:alpha="0.5" />

            <View
                android:layout_width="32dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:background="@drawable/bottom_sheet_handle"
                android:alpha="0.3" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="@android:color/white"
            app:elevation="20dp"
            app:cardElevation="0dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:paddingTop="8dp">

                    <!-- Header Section - FIXED SETTINGS BUTTON -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="28dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/discover_places"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/black"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="-0.02" />

                        <!-- FIXED: Using AppCompatImageButton instead of MaterialButton -->
                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btn_settings"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@android:drawable/ic_menu_manage"
                            android:contentDescription="@string/settings"
                            android:background="@drawable/circular_background"
                            app:tint="@android:color/black"
                            android:padding="12dp"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Quick Actions Section with Enhanced Cards -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_actions"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="20dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.01" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:rowCount="2"
                        android:alignmentMode="alignMargins"
                        android:columnOrderPreserved="false"
                        android:layout_marginBottom="36dp"
                        android:padding="4dp">

                        <!-- Apartment Card - Enhanced -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/apartment_card"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:layout_rowWeight="1"
                            app:cardCornerRadius="20dp"
                            app:strokeColor="?attr/colorPrimary"
                            app:strokeWidth="0dp"
                            app:cardElevation="2dp"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:stateListAnimator="@animator/card_state_animator">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <ImageView
                                    android:id="@+id/apartment"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_apartment"
                                    app:tint="?attr/colorPrimary"
                                    android:alpha="0.9" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/apartment"
                                    android:textSize="13sp"
                                    android:textColor="@android:color/black"
                                    android:layout_marginTop="10dp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Add Room Card - Enhanced -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/addRoom_card"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:layout_rowWeight="1"
                            app:cardCornerRadius="20dp"
                            app:strokeColor="?attr/colorPrimary"
                            app:strokeWidth="0dp"
                            app:cardElevation="2dp"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:stateListAnimator="@animator/card_state_animator">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <ImageView
                                    android:id="@+id/addRoom"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_addd"
                                    app:tint="?attr/colorPrimary"
                                    android:alpha="0.9" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/add_room"
                                    android:textSize="13sp"
                                    android:textColor="@android:color/black"
                                    android:layout_marginTop="10dp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Language Card - Enhanced -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/language_card"
                            android:layout_width="0dp"
                            android:layout_height="120dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="6dp"
                            android:layout_rowWeight="1"
                            app:cardCornerRadius="20dp"
                            app:strokeColor="?attr/colorPrimary"
                            app:strokeWidth="0dp"
                            app:cardElevation="2dp"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:stateListAnimator="@animator/card_state_animator">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@drawable/ic_state"
                                    app:tint="?attr/colorPrimary"
                                    android:alpha="0.9" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/language"
                                    android:textSize="13sp"
                                    android:textColor="@android:color/black"
                                    android:layout_marginTop="10dp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </GridLayout>

                    <!-- Recent Searches Section with Enhanced Design -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/recent_searches"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="20dp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="-0.01" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- UDSM Item - Enhanced -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:cardCornerRadius="16dp"
                            app:strokeColor="@color/text_secondary"
                            app:strokeWidth="0.5dp"
                            app:cardElevation="1dp"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/circular_background_primary"
                                    android:gravity="center"
                                    android:layout_marginEnd="16dp">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_save"
                                        app:tint="?attr/colorPrimary" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/contact"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="University of Dar es Salaam"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:textColor="@android:color/black"
                                        android:fontFamily="sans-serif-medium" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/university_of_dar_es_salaam"
                                        android:textSize="13sp"
                                        android:textColor="@color/text_secondary"
                                        android:layout_marginTop="4dp" />
                                </LinearLayout>

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_back"
                                    app:tint="@color/text_secondary"
                                    android:alpha="0.6" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Bus Office Item - Enhanced -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="16dp"
                            app:strokeColor="@color/text_secondary"
                            app:strokeWidth="0.5dp"
                            app:cardElevation="1dp"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/circular_background_secondary"
                                    android:gravity="center"
                                    android:layout_marginEnd="16dp">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:src="@drawable/ic_bath"
                                        app:tint="@color/secondary" />
                                </LinearLayout>


                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_close"
                                    app:tint="@color/text_secondary"
                                    android:alpha="0.6" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Language Selection (Hidden by default, shows on tap) - Enhanced -->
                    <LinearLayout
                        android:id="@+id/language_selection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="32dp"
                        android:padding="16dp"
                        android:background="@drawable/language_selection_background"
                        android:visibility="gone"
                        android:gravity="center">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_english"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="English"
                            android:layout_marginEnd="12dp"
                            app:chipBackgroundColor="@color/chip_background"
                            app:checkedIcon="@drawable/ic_room_available"
                            app:chipIcon="@drawable/ic_english"
                            app:chipIconTint="?attr/colorPrimary" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_swahili"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/swahili"
                            app:chipBackgroundColor="@color/chip_background"
                            app:checkedIcon="@drawable/ic_room_occupied"
                            app:chipIcon="@drawable/ic_swahili"
                            app:chipIconTint="?attr/colorPrimary" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Fixed Bottom Navigation Section -->
    <LinearLayout
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:weightSum="3">

        <!-- Menu Tab -->
        <LinearLayout
            android:id="@+id/tab_menu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Ride Tab -->
        <LinearLayout
            android:id="@+id/tab_ride"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_add"
                app:tint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ride"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Profile Tab -->
        <LinearLayout
            android:id="@+id/tab_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>